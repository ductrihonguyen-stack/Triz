-- CHỨC NĂNG 1: FLY ENGINE (MẶC ĐỊNH SỐ 80)
local function startFlyingEngine()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    local humanoid = character:WaitForChild("Humanoid")
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = hrp
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    bodyGyro.CFrame = hrp.CFrame
    bodyGyro.Parent = hrp
    
    humanoid.PlatformStand = true
    
    flyConnection = RunService.RenderStepped:Connect(function()
        if not States.Fly or not hrp or not humanoid then return end
        bodyGyro.CFrame = Camera.CFrame
        
        local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude > 0 then
            local camX = Camera.CFrame.RightVector
            local camZ = Camera.CFrame.LookVector
            
            local forwardForce = moveDirection:Dot(Vector3.new(camZ.X, 0, camZ.Z).Unit)
            local rightForce = moveDirection:Dot(Vector3.new(camX.X, 0, camX.Z).Unit)
            
            local finalFlyVector = (camZ * forwardForce) + (camX * rightForce)
            if finalFlyVector.Magnitude > 0 then finalFlyVector = finalFlyVector.Unit end
            
            bodyVelocity.Velocity = finalFlyVector * States.FlySpeed
        else
            bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end)
end

local function stopFlyingEngine()
    if flyConnection then flyConnection:Disconnect() flyConnection = nil end
    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
    
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.PlatformStand = false end
    end
end

createSharkToggle("FLY ENGINE", "Bay tự do (Mặc định tốc độ 80)", "🚀", States.Fly, function(state)
    States.Fly = state
    if state then startFlyingEngine() else stopFlyingEngine() end
end)

createSharkSlider("FLY SPEED", "Tốc độ bay tự do nhân vật", "⚡", 1, 999999, States.FlySpeed, function(val)
    States.FlySpeed = val
end)


-- CHỨC NĂNG 2: AIMBOT CAMERA LOCK-ON (KHÔNG LỆCH)
local function checkLineOfSight(character, targetPart)
    if not LocalPlayer.Character then return false end
    local origin = Camera.CFrame.Position
    local direction = targetPart.Position - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character, character}
    
    local res = workspace:Raycast(origin, direction, params)
    return res == nil
end

local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local part = p.Character:FindFirstChild(TARGET_PART) 
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if part and hum and hum.Health > 0 then
                if checkLineOfSight(p.Character, part) then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                        if dist <= FOV_RADIUS and dist < shortestDistance then
                            closestPlayer = p
                            shortestDistance = dist
                        end
                    end
                end
            end
        end
    end
    return closestPlayer
end

local function updateAimbot()
    if not States.Aimbot then return end
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    if not CurrentTarget or not CurrentTarget.Character or not CurrentTarget.Character:FindFirstChild(TARGET_PART) or (CurrentTarget.Character:FindFirstChildOfClass("Humanoid") and CurrentTarget.Character:FindFirstChildOfClass("Humanoid").Health <= 0) then
        CurrentTarget = getClosestPlayer()
    else
        local part = CurrentTarget.Character[TARGET_PART]
        if not checkLineOfSight(CurrentTarget.Character, part) then
            CurrentTarget = nil
            return
        end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if onScreen then
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
            if dist > FOV_RADIUS then
                CurrentTarget = nil 
                return
            end
        else
            CurrentTarget = nil
            return
        end
    end

    if CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild(TARGET_PART) then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, CurrentTarget.Character[TARGET_PART].Position)
    end
end

createSharkToggle("AIMBOT LOCK", "Khóa ngắm camera góc nhìn 1/3", "🎯", States.Aimbot, function(state)
    States.Aimbot = state
    if state then
        FOVCircle.Visible = true
        RunService:BindToRenderStep("SharkLockOnMobile", Enum.RenderPriority.Camera.Value + 1, updateAimbot)
    else
        FOVCircle.Visible = false
        RunService:UnbindFromRenderStep("SharkLockOnMobile")
        CurrentTarget = nil
    end
end)


