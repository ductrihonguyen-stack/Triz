-- --- [ 7. ĐỘNG CƠ KÉO THẢ DI ĐỘNG ] ---
local function makeMobileSmoothDrag(targetFrame, handleArea)
    local dragToggle = false
    local dragStart = nil
    local startPos = nil

    handleArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragToggle = true
            dragStart = input.Position
            startPos = Vector2.new(targetFrame.Position.X.Offset, targetFrame.Position.Y.Offset)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            targetFrame.Position = UDim2.new(
                targetFrame.Position.X.Scale, 
                startPos.X + delta.X, 
                targetFrame.Position.Y.Scale, 
                startPos.Y + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragToggle = false
        end
    end)
end

makeMobileSmoothDrag(MainContainer, UnifiedDragBar)


-- --- [ 8. ĐỘNG CƠ THÔNG MINH CHO NÚT KHỞI ĐỘNG 🦈 ] ---
local function makeButtonSmartEngine(btnFrame, clickCallback)
    local dragging = false
    local dragStart = nil
    local startPos = nil
    local hasMovedSignificant = false

    btnFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            hasMovedSignificant = false
            dragStart = input.Position
            startPos = Vector2.new(btnFrame.Position.X.Offset, btnFrame.Position.Y.Offset)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            if delta.Magnitude > 5 then
                hasMovedSignificant = true
            end
            btnFrame.Position = UDim2.new(
                btnFrame.Position.X.Scale, 
                startPos.X + delta.X, 
                btnFrame.Position.Y.Scale, 
                startPos.Y + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                dragging = false
                if not hasMovedSignificant and btnFrame.Visible then
                    clickCallback()
                end
            end
        end
    end)
end

makeButtonSmartEngine(OpenBtn, function()
    MainContainer.Visible = true
    OpenBtn.Visible = false
end)


-- --- [ 9. THUẬT TOÁN LOGIC ĐỘNG CƠ FLY 3D MOBILE ] ---
local isFlying = false
local currentFlySpeed = 20
local flyConnection = nil
local bodyVelocity = nil
local bodyGyro = nil

local function startFlyingEngine()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    local humanoid = character:WaitForChild("Humanoid")
    local camera = workspace.CurrentCamera
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = hrp
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    bodyGyro.CFrame = hrp.CFrame
    bodyGyro.Parent = hrp
    
    humanoid.PlatformStand = true
    
    flyConnection = RunService.RenderStepped:Connect(function()
        if not isFlying or not hrp or not humanoid then return end
        bodyGyro.CFrame = camera.CFrame
        
        local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude > 0 then
            local camX = camera.CFrame.RightVector
            local camZ = camera.CFrame.LookVector
            
            local forwardForce = moveDirection:Dot(Vector3.new(camZ.X, 0, camZ.Z).Unit)
            local rightForce = moveDirection:Dot(Vector3.new(camX.X, 0, camX.Z).Unit)
            
            local finalFlyVector = (camZ * forwardForce) + (camX * rightForce)
            if finalFlyVector.Magnitude > 0 then finalFlyVector = finalFlyVector.Unit end
            
            bodyVelocity.Velocity = finalFlyVector * currentFlySpeed
        else
            bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end)
end

local function stopFlyingEngine()
    if flyConnection then flyConnection:Disconnect() flyConnection = nil end
    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
    
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid.PlatformStand = false end
    end
end

