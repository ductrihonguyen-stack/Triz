        local holding = false
        button.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                holding = true
                update(current + step)
                task.wait(0.4)
                while holding do
                    update(current + step)
                    task.wait(0.03)
                end
            end
        end)
        button.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                holding = false
            end
        end)
    end

    setupHold(Minus, -1)
    setupHold(Plus, 1)

    ValBox:GetPropertyChangedSignal("Text"):Connect(function()
        local clean = ValBox.Text:gsub("%D", "")
        if ValBox.Text ~= clean then ValBox.Text = clean end
        local num = tonumber(clean)
        if num then
            current = math.clamp(num, minVal, maxVal)
            callback(current)
        end
    end)

    ValBox.FocusLost:Connect(function() update(current) end)
end


