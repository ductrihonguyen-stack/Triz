-- --- [ NÂNG CẤP MỚI: BỘ LỌC CHỮ KHI TỰ GÕ BẰNG BÀN PHÍM TỰ ĐỘNG KHÓA CHỮ ] ---
ValueLabel:GetPropertyChangedSignal("Text"):Connect(function()
    -- Dùng Regex để tìm và xóa sạch các ký tự KHÔNG PHẢI LÀ SỐ (%D) ngay khi đang gõ
    local cleanNumbers = ValueLabel.Text:gsub("%D", "")
    
    if ValueLabel.Text ~= cleanNumbers then
        ValueLabel.Text = cleanNumbers -- Ép xóa chữ ngay trên màn hình bàn phím
    end
    
    -- Áp dụng số vừa gõ vào tốc độ bay thực tế
    local numericValue = tonumber(cleanNumbers)
    if numericValue then
        currentFlySpeed = math.clamp(numericValue, 1, 300) -- Khóa tốc độ trong khoảng an toàn 1 - 300
    end
end)

-- Khi người dùng tắt bàn phím/bấm ra ngoài màn hình
