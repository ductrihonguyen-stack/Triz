-- --- [ HÀM HIỆU ỨNG ANIMATION QUAD SMOOTH ] ---
local function playPopUpAnimation(frame, open, targetSize, callback)
    frame.AnchorPoint = Vector2.new(0.5, 0.5)
    frame.Position = UDim2.new(0.5, 0, 0.5, 0)
    frame.ClipsDescendants = true
    
    if open then
        frame.Size = UDim2.new(0, 0, 0, 0)
        frame.Visible = true
        local tween = TweenService:Create(frame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingStyle.Out), {Size = targetSize})
        tween:Play()
        if callback then 
            local c; c = tween.Completed:Connect(function() c:Disconnect() callback() end) 
        end
    else
        local tween = TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingStyle.In), {Size = UDim2.new(0, 0, 0, 0)})
        tween:Play()
        local c; c = tween.Completed:Connect(function() 
            c:Disconnect() 
            frame.Visible = false
            if callback then callback() end 
        end)
    end
end

-- --- [ HÀM KÉO THẢ MƯỢT MÀ ] ---
local function makeSmoothDrag(targetFrame, handleArea)
    local dragToggle, dragStart, startPos = false, nil, nil
    handleArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragToggle = true; dragStart = input.Position; startPos = Vector2.new(targetFrame.Position.X.Offset, targetFrame.Position.Y.Offset)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            targetFrame.Position = UDim2.new(targetFrame.Position.X.Scale, startPos.X + delta.X, targetFrame.Position.Y.Scale, startPos.Y + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragToggle = false end
    end)
end

