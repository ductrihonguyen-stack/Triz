local function applyHitboxToCharacter(character)
    if not character then return end
    
    -- Xóa Highlight cũ nếu có trước khi áp dụng mới để tránh lỗi trùng lặp dữ liệu cũ
    local oldHighlight = character:FindFirstChild("ESP_Highlight")
    if oldHighlight then oldHighlight:Destroy() end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.Enabled = States.Hitbox
    highlight.Parent = character
end

local function cleanPlayerESP(player)
    if player.Character then
        local highlight = player.Character:FindFirstChild("ESP_Highlight")
        if highlight then highlight:Destroy() end
    end
end

local function managePlayerTrack(player)
    if player == LocalPlayer then return end
    
    -- Lắng nghe nếu nhân vật của họ hồi sinh/xuất hiện mới
    local conn = player.CharacterAdded:Connect(function(char)
        task.wait(0.8) -- Thời gian chờ an toàn đảm bảo nhân vật load xong cấu trúc xương cơ thể trên Mobile
        if States.Hitbox then
            applyHitboxToCharacter(char)
        end
    end)
    
    PlayerConnections[player] = conn
    
    -- Nếu nhân vật đã có sẵn từ trước, áp dụng luôn
    if player.Character then
        applyHitboxToCharacter(player.Character)
    end
end

-- Vòng lặp cập nhật trạng thái khi nhấn nút ON/OFF
local function updateESP()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hl = plr.Character:FindFirstChild("ESP_Highlight")
            if hl then
                hl.Enabled = States.Hitbox
            elseif States.Hitbox then
                applyHitboxToCharacter(plr.Character)
            end
        end
    end
end

-- Khởi động hệ thống theo dõi người chơi toàn bộ Server
for _, plr in ipairs(Players:GetPlayers()) do
    managePlayerTrack(plr)
end

Players.PlayerAdded:Connect(managePlayerTrack)

Players.PlayerRemoving:Connect(function(plr)
    if PlayerConnections[plr] then
        PlayerConnections[plr]:Disconnect()
        PlayerConnections[plr] = nil
    end
end)

createSharkToggle("HITBOX", "Hiển thị hitbox người chơi (Chống lỗi hồi sinh)", "📦", States.Hitbox, function(state)
    States.Hitbox = state
    updateESP()
end)


-- --- [ 8. DẢI KÉO THẢ VÔ HÌNH HIỆN ĐẠI ] ---
local UnifiedDragBar = Instance.new("Frame")
UnifiedDragBar.Name = "UnifiedDragBar"
UnifiedDragBar.Size = UDim2.new(1, -60, 0, 110) 
UnifiedDragBar.BackgroundTransparency = 0.99 
UnifiedDragBar.Active = true
UnifiedDragBar.ZIndex = 8
UnifiedDragBar.Parent = MainContainer

local function makeMobileSmoothDrag(targetFrame, handleArea)
    local dragToggle = false
    local dragStart = nil
    local startPos = nil

    handleArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragToggle = true
            dragStart = input.Position
            startPos = Vector2.new(targetFrame.Position.X.Offset, targetFrame.Position.Y.Offset)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragToggle and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            targetFrame.Position = UDim2.new(
                targetFrame.Position.X.Scale, 
                startPos.X + delta.X, 
                targetFrame.Position.Y.Scale, 
                startPos.Y + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragToggle = false
        end
    end)
end

makeMobileSmoothDrag(MainContainer, UnifiedDragBar)


-- --- [ 9. ĐỘNG CƠ THÔNG MINH CHO NÚT MỞ 🦈 ] ---
local function makeButtonSmartEngine(btnFrame, clickCallback)
    local dragging = false
    local dragStart = nil
    local startPos = nil
    local hasMovedSignificant = false

    btnFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            hasMovedSignificant = false
            dragStart = input.Position
            startPos = Vector2.new(btnFrame.Position.X.Offset, btnFrame.Position.Y.Offset)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            if delta.Magnitude > 5 then
                hasMovedSignificant = true
            end
            btnFrame.Position = UDim2.new(
                btnFrame.Position.X.Scale, 
                startPos.X + delta.X, 
                btnFrame.Position.Y.Scale, 
                startPos.Y + delta.Y
            )
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                dragging = false
                if not hasMovedSignificant and btnFrame.Visible then
                    clickCallback()
                end
            end
        end
    end)
end

makeButtonSmartEngine(OpenBtn, function()
    MainContainer.Visible = true
    OpenBtn.Visible = false
end)


-- --- [ 10. NÚT PHỤ TRỢ THU NHỎ / ĐÓNG ] ---
MinimizeBtn.MouseButton1Click:Connect(function()
    MainContainer.Visible = false
    OpenBtn.Visible = true
end)

CloseBtn.MouseButton1Click:Connect(function()
    stopFlyingEngine()
    
    -- Dọn dẹp Highlight ESP khi tắt Menu
    for _, plr in pairs(Players:GetPlayers()) do
        cleanPlayerESP(plr)
    end
    
    -- Ngắt toàn bộ kết nối tránh lỗi bộ nhớ
    for plr, conn in pairs(PlayerConnections) do
        if conn then conn:Disconnect() end
    end
    table.clear(PlayerConnections)

    if flyConnection then flyConnection:Disconnect() end
    RunService:UnbindFromRenderStep("SharkLockOnMobile")
    ScreenGui:Destroy()
end)
