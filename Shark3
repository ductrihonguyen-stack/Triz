-- CHỨC NĂNG 2: AIMBOT CAMERA LOCK-ON
local function checkLineOfSight(character, targetPart)
    if not LocalPlayer.Character then return false end
    local origin = Camera.CFrame.Position
    local direction = targetPart.Position - origin
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {LocalPlayer.Character, character}
    
    local res = workspace:Raycast(origin, direction, params)
    return res == nil
end

local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local part = p.Character:FindFirstChild(TARGET_PART) 
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if part and hum and hum.Health > 0 then
                if checkLineOfSight(p.Character, part) then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                        if dist <= FOV_RADIUS and dist < shortestDistance then
                            closestPlayer = p
                            shortestDistance = dist
                        end
                    end
                end
            end
        end
    end
    return closestPlayer
end

local function updateAimbot()
    if not States.Aimbot then return end
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    if not CurrentTarget or not CurrentTarget.Character or not CurrentTarget.Character:FindFirstChild(TARGET_PART) or (CurrentTarget.Character:FindFirstChildOfClass("Humanoid") and CurrentTarget.Character:FindFirstChildOfClass("Humanoid").Health <= 0) then
        CurrentTarget = getClosestPlayer()
    else
        local part = CurrentTarget.Character[TARGET_PART]
        if not checkLineOfSight(CurrentTarget.Character, part) then
            CurrentTarget = nil
            return
        end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if onScreen then
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
            if dist > FOV_RADIUS then
                CurrentTarget = nil 
                return
            end
        else
            CurrentTarget = nil
            return
        end
    end

    if CurrentTarget and CurrentTarget.Character and CurrentTarget.Character:FindFirstChild(TARGET_PART) then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, CurrentTarget.Character[TARGET_PART].Position)
    end
end

createSharkToggle("AIMBOT LOCK", "Khóa ngắm camera góc nhìn 1/3", "🎯", States.Aimbot, function(state)
    States.Aimbot = state
    if state then
        FOVCircle.Visible = true
        RunService:BindToRenderStep("SharkLockOnMobile", Enum.RenderPriority.Camera.Value + 1, updateAimbot)
    else
        FOVCircle.Visible = false
        RunService:UnbindFromRenderStep("SharkLockOnMobile")
        CurrentTarget = nil
    end
end)


