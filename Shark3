local function startFlyingEngine()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = character:WaitForChild("HumanoidRootPart")
    local humanoid = character:WaitForChild("Humanoid")
    bodyVelocity = Instance.new("BodyVelocity") bodyVelocity.MaxForce = Vector3.new(1e6, 1e6, 1e6) bodyVelocity.Velocity = Vector3.new(0, 0, 0) bodyVelocity.Parent = hrp
    bodyGyro = Instance.new("BodyGyro") bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6) bodyGyro.CFrame = hrp.CFrame bodyGyro.Parent = hrp
    humanoid.PlatformStand = true
    flyConnection = RunService.RenderStepped:Connect(function()
        if not States.Fly or not hrp or not humanoid then return end
        bodyGyro.CFrame = Camera.CFrame
        local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude > 0 then
            local camX = Camera.CFrame.RightVector
            local camZ = Camera.CFrame.LookVector
            local forwardForce = moveDirection:Dot(Vector3.new(camZ.X, 0, camZ.Z).Unit)
            local rightForce = moveDirection:Dot(Vector3.new(camX.X, 0, camX.Z).Unit)
            bodyVelocity.Velocity = ((camZ * forwardForce) + (camX * rightForce)).Unit * States.FlySpeed
        else bodyVelocity.Velocity = Vector3.new(0, 0, 0) end
    end)
end

local function stopFlyingEngine()
    if flyConnection then flyConnection:Disconnect() flyConnection = nil end
    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then LocalPlayer.Character:FindFirstChildOfClass("Humanoid").PlatformStand = false end
end

createSharkToggle("FLY ENGINE", "Bay tự do không giới hạn địa hình", "🚀", States.Fly, function(state)
    States.Fly = state if state then startFlyingEngine() else stopFlyingEngine() end
end)

createSharkSlider("FLY SPEED", "Cân chỉnh tốc độ bay nhân vật", "⚡", 1, 1000, States.FlySpeed, function(val) States.FlySpeed = val end)

local function checkLineOfSight(character, targetPart)
    if not LocalPlayer.Character then return false end
    local params = RaycastParams.new() params.FilterType = Enum.RaycastFilterType.Exclude; params.FilterDescendantsInstances = {LocalPlayer.Character, character}
    return workspace:Raycast(Camera.CFrame.Position, targetPart.Position - Camera.CFrame.Position, params) == nil
end

local function getClosestPlayer()
    local closest, shortest = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(TARGET_PART) and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            if checkLineOfSight(p.Character, p.Character[TARGET_PART]) then
                local screenPos, onScreen = Camera:WorldToViewportPoint(p.Character[TARGET_PART].Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist <= FOV_RADIUS and dist < shortest then closest = p; shortest = dist end
                end
            end
        end
    end
    return closest
end

createSharkToggle("AIMBOT LOCK", "Tự động khóa mục tiêu trong tầm ngắm", "🎯", States.Aimbot, function(state)
    States.Aimbot = state FOVCircle.Visible = state
    if state then
        RunService:BindToRenderStep("SharkLock", Enum.RenderPriority.Camera.Value + 1, function()
            if not States.Aimbot then return end
            if not CurrentTarget or not CurrentTarget.Character or not CurrentTarget.Character:FindFirstChild(TARGET_PART) or CurrentTarget.Character:FindFirstChildOfClass("Humanoid").Health <= 0 then
                CurrentTarget = getClosestPlayer()
            else
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, CurrentTarget.Character[TARGET_PART].Position)
            end
        end)
    else RunService:UnbindFromRenderStep("SharkLock") CurrentTarget = nil end
end)

local function applyHitboxToCharacter(character)
    if not character then return end
    local old = character:FindFirstChild("ESP_Highlight") if old then old:Destroy() end
    local hl = Instance.new("Highlight") hl.Name = "ESP_Highlight" hl.FillColor = Color3.fromRGB(0, 255, 200) hl.FillTransparency = 0.45 hl.Enabled = States.Hitbox hl.Parent = character
end

createSharkToggle("HITBOX HIT ESP", "Bật hộp Hitbox phát quang chống lỗi hồi sinh", "📦", States.Hitbox, function(state)
    States.Hitbox = state
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hl = p.Character:FindFirstChild("ESP_Highlight")
            if hl then hl.Enabled = state else if state then applyHitboxToCharacter(p.Character) end end
        end
    end
end)

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then
        p.CharacterAdded:Connect(function(c) task.wait(0.6) if States.Hitbox then applyHitboxToCharacter(c) end end)
        if p.Character then applyHitboxToCharacter(p.Character) end
    end
end
